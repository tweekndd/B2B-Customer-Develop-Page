# =============================================================================
# B2B Customer Develop Platform — 环境变量配置
# 复制此文件为 .env，然后逐项填写
#   cp .env.example .env
# =============================================================================

# ─── 必填 ─────────────────────────────────────────────────────────────

# SearXNG 秘钥（任意随机字符串，用于内部签名）
SEARXNG_SECRET_KEY=请改为随机字符串，例如 openssl rand -hex 32

# Session 签名秘钥（用于用户登录会话加密）
SESSION_SECRET=请改为另一随机字符串

# ─── AI 分析 ─────────────────────────────────────────────────────────

# 智谱 GLM API（免费 | 用于 AI 客户分析）
# 申请地址: https://open.bigmodel.cn/
GLM_API_KEY=your_glm_api_key_here

# ─── 搜索引擎（二选一或全配） ────────────────────────────────────────

# SearXNG 已由 docker-compose 自动配置，默认 http://searxng:8080
# 如需外部 SearXNG 实例，取消注释并修改 URL：
# SEARXNG_URL=http://your-searxng-host:8888

# Tavily API Key（可选，付费）
# TAVILY_API_KEY=your_tavily_key_here

# SerpAPI API Key（可选，付费）
# SERPAPI_API_KEY=your_serpapi_key_here

# 强制指定搜索引擎（可选：searxng / tavily / serpapi）
# 不设置则按优先级自动检测：SearXNG > Tavily > SerpAPI
# SEARCH_ENGINE=searxng

# ─── 邮箱查找（可选） ────────────────────────────────────────────────

# Hunter API（可选）
# HUNTER_API_KEY=your_hunter_api_key_here

# Tomba API（可选）
# TOMBA_API_KEY=your_tomba_api_key_here
# TOMBA_API_SECRET=your_tomba_api_secret_here

# Prospeo API（可选）
# PROSPEO_API_KEY=your_prospeo_api_key_here

# ─── 管理员账号（首次启动自动创建） ──────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=请改为强密码

# ─── 数据库（可选） ─────────────────────────────────────────────────

# 留空 = 使用 SQLite（文件存储在 Docker 卷中，简单够用）
# 设置后切换为 PostgreSQL（需 docker-compose 中启用 db 服务）
# DATABASE_URL=postgresql://b2b:密码@db:5432/b2b_customers
DB_USER=b2b
DB_PASSWORD=请改为数据库密码
DB_NAME=b2b_customers

# ─── 可选调优 ───────────────────────────────────────────────────────

# 缓存有效期（秒），默认 7 天
# HUNTER_CACHE_TTL=604800
# TOMBA_CACHE_TTL=604800
# PROSPEO_CACHE_TTL=604800

# 请求间隔（秒），避免触发限流
# HUNTER_REQUEST_DELAY=0.3
# TOMBA_REQUEST_DELAY=0.3
# PROSPEO_REQUEST_DELAY=0.5
